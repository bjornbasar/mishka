APP_ENV=dev
# v0.5.0: APP_URL is REQUIRED at boot — UrlBuilder uses it for absolute URLs
# in outbound emails (B1: never read $request->header('host') for email links).
APP_URL=http://localhost:8080

# PostgreSQL on Nalle (port 5433 to avoid conflict with system pg)
DB_DSN=pgsql:host=192.168.4.9;port=5433;dbname=mishka
DB_USER=mishka
DB_PASS=

# v0.5.0: email transport. Dev = MailHog at /data/personal/docker-compose.yml
# (profiles: ["mishka"], started via `docker compose --profile mishka up -d mailhog`).
# Prod: Postmark recommended (smtp://apikey:<token>@smtp.postmarkapp.com:587?
# timeout=5&encryption=tls). `?timeout=5` prevents 60s request hangs when the
# SMTP server is unreachable.
MAILER_DSN=smtp://mailhog:1025?timeout=5
MAIL_FROM_ADDRESS=noreply@mishka.local
# Values with whitespace MUST be quoted (vlucas/phpdotenv rejects bare spaces).
MAIL_FROM_NAME="Mishka Den"
