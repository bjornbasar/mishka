{% extends "layout.twig" %}

{% block title %}Register — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>Create your account</h1>
    <p>Welcome. You'll be the first member of your household — that makes you the admin once you sign up.</p>

    {% if errors %}
        <ul class="errors">
            {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    <form method="POST" action="/register" class="auth">
        {{ csrf_field() }}
        <label>
            Email
            <input type="email" name="email" required autofocus
                   maxlength="320" value="{{ old.email|default('') }}">
        </label>
        <label>
            Display name (optional)
            <input type="text" name="display_name" maxlength="120"
                   value="{{ old.display_name|default('') }}">
        </label>
        <label>
            Password
            <input type="password" name="password" required minlength="12" maxlength="128">
        </label>
        <label>
            Confirm password
            <input type="password" name="password_confirm" required minlength="12" maxlength="128">
        </label>
        <button type="submit">Create account</button>
    </form>

    <p>Already have an account? <a href="/login">Sign in</a>.</p>
{% endblock %}
