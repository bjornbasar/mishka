{% extends "layout.twig" %}

{% block title %}Sign in — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>Sign in</h1>

    {# v0.5.0 flash query params (passed from AuthController::showLogin):
       - ?reset=ok               PasswordResetController after a successful reset (no auto-login).
       - ?reason=password_changed SessionRevocationGuard bounce when a session's auth_time
                                  predates the user's password_changed_at stamp.
       v0.6.12 adds:
       - ?deleted=1              AccountController::handleDelete after a successful account
                                  delete (session is destroyed; can't use a session-flash). #}
    {% if reset|default('') == 'ok' %}
        <div class="flash">Password reset — sign in with your new password.</div>
    {% elseif reason|default('') == 'password_changed' %}
        <div class="flash">Your password was changed elsewhere. Please sign in again.</div>
    {% elseif deleted|default('') == '1' %}
        <div class="flash">Your account has been deleted.</div>
    {% endif %}

    {% if errors %}
        <ul class="errors">
            {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    <form method="POST" action="/login" class="auth">
        {{ csrf_field() }}
        <label>
            Email
            <input type="email" name="email" required autofocus
                   maxlength="320" value="{{ old.email|default('') }}">
        </label>
        <label>
            Password
            <input type="password" name="password" required>
        </label>
        <p style="margin: -0.5rem 0 0; font-size: 0.875rem;">
            <a href="/password-reset">Forgot password?</a>
        </p>
        <button type="submit">Sign in</button>
    </form>

    <p>New here? <a href="/register">Create an account</a>.</p>
{% endblock %}
