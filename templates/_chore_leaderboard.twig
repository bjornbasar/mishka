{#
    Shared leaderboard row macro (v0.4.3, extended v0.5.1 with missed-count).
    Imported by both `templates/chores/index.twig` and `templates/home.twig` so
    the two pages can't drift in markup.

    Expects each `member` row to carry:
      display_name, email, week_points, total_points,
      badges (list<string>),  streak (int),  daily_streak (int, v0.6.14),
      missed_count (int, v0.5.1)

    The badge presentation (emoji + title) is looked up from the `badge_meta`
    Twig global registered in public/index.php (config/badges.php).

    `missed_count` shows as ⏰ N only when > 0 — zero-suppressed so high
    performers don't get a flat `⏰ 0` that reads as a badge. Purely
    observational; no points are deducted (v0.5.1 design decision).
#}
{% macro row(member) %}
    <li style="margin:0.15rem 0;">
        <strong>{{ member.display_name ?: member.email }}</strong>
        {{ member.week_points }} this wk
        <small style="color:var(--muted);">· {{ member.total_points }} all-time</small>
        {% if member.streak is defined and member.streak >= 2 %}
            <span title="{{ member.streak }}-week streak" style="margin-left:0.4rem;">🔥 {{ member.streak }}</span>
        {% endif %}
        {% if member.daily_streak is defined and member.daily_streak >= 2 %}
            <span title="{{ member.daily_streak }}-day streak" style="margin-left:0.4rem;">📅 {{ member.daily_streak }}</span>
        {% endif %}
        {% if member.badges is defined %}
            {% for code in member.badges %}
                {# v0.6.13: badge emoji is a link to /badges (no nested anchors — the leaderboard row has no outer <a>). #}
                <a href="/badges" title="{{ badge_meta[code].title }}" style="margin-left:0.25rem; text-decoration:none;">{{ badge_meta[code].emoji }}</a>
            {% endfor %}
        {% endif %}
        {% if member.missed_count is defined and member.missed_count > 0 %}
            <span title="{{ member.missed_count }} chore{{ member.missed_count == 1 ? '' : 's' }} past due — no points lost, just a heads-up"
                  style="margin-left:0.4rem; color:var(--muted);">⏰ {{ member.missed_count }}</span>
        {% endif %}
    </li>
{% endmacro %}
