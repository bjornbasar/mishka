{% extends "layout.twig" %}

{% block title %}{{ mode == 'edit' ? 'Edit event' : 'New event' }} — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>{{ mode == 'edit' ? 'Edit event' : 'New event' }}</h1>

    {% if errors %}
        <ul class="errors">
            {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    <form method="POST"
          action="{{ mode == 'edit' ? '/calendar/events/' ~ event.id : '/calendar/events' }}"
          class="auth">
        {{ csrf_field() }}

        {% if mode == 'edit' %}
            <input type="hidden" name="_expected_updated_at" value="{{ event.updated_at }}">
            <input type="hidden" name="_expected_exception_count" value="{{ exception_count|default(0) }}">
        {% endif %}

        <label>
            Title
            <input type="text" name="title" required maxlength="200" value="{{ event.title|default('') }}" autofocus>
        </label>

        <label>
            Start
            <input type="datetime-local" name="starts_at_local" required value="{{ event.starts_at_local|default('') }}">
        </label>

        <label>
            End
            <input type="datetime-local" name="ends_at_local" required value="{{ event.ends_at_local|default('') }}">
        </label>

        <label>
            Location <small style="color:var(--muted)">(optional)</small>
            <input type="text" name="location" maxlength="200" value="{{ event.location|default('') }}">
        </label>

        <label>
            Description <small style="color:var(--muted)">(optional)</small>
            <textarea name="description" rows="3">{{ event.description|default('') }}</textarea>
        </label>

        <label style="flex-direction:row; align-items:center; gap:0.5rem;">
            <input type="checkbox" name="all_day" value="1" {% if event.all_day|default(false) %}checked{% endif %}>
            All day
        </label>

        <fieldset class="recurrence-fieldset" style="border:1px solid var(--border); padding:0.75rem 1rem; border-radius:0.375rem; margin:0;">
            <legend style="padding:0 0.4rem;">Repeats</legend>
            <label style="margin-top:0;">
                <select name="recurrence_preset">
                    <option value="none"    {% if recurrence.preset == 'none' %}selected{% endif %}>Does not repeat</option>
                    <option value="daily"   {% if recurrence.preset == 'daily' %}selected{% endif %}>Daily</option>
                    <option value="weekly"  {% if recurrence.preset == 'weekly' %}selected{% endif %}>Weekly</option>
                    <option value="monthly" {% if recurrence.preset == 'monthly' %}selected{% endif %}>Monthly</option>
                    <option value="yearly"  {% if recurrence.preset == 'yearly' %}selected{% endif %}>Yearly</option>
                    {% if recurrence.preset == 'custom' %}<option value="custom" selected>Custom (read-only)</option>{% endif %}
                </select>
            </label>

            <label class="recurrence-weekly" style="display:none;">
                Days of week
                <span style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-top:0.25rem;">
                    {% for code, name in {'MO':'Mon','TU':'Tue','WE':'Wed','TH':'Thu','FR':'Fri','SA':'Sat','SU':'Sun'} %}
                        <label style="flex-direction:row; align-items:center; gap:0.25rem; padding:0.25rem 0.5rem; border:1px solid var(--border); border-radius:0.25rem;">
                            <input type="checkbox" name="recurrence_byday[]" value="{{ code }}"
                                   {% if code in recurrence.byday %}checked{% endif %}>
                            {{ name }}
                        </label>
                    {% endfor %}
                </span>
            </label>

            <label class="recurrence-monthly" style="display:none;">
                Day of month <small style="color:var(--muted);">(1–28)</small>
                <input type="number" name="recurrence_monthly_day" min="1" max="28"
                       value="{{ recurrence.monthly_day|default(1) }}">
            </label>

            <label class="recurrence-interval" style="display:none;">
                Repeat every <small style="color:var(--muted);">(1 = every period)</small>
                <input type="number" name="recurrence_interval" min="1" max="52"
                       value="{{ recurrence.interval|default(1) }}">
            </label>
        </fieldset>

        <p style="color:var(--muted); font-size:0.9em;">
            Times are in <strong>{{ household.timezone }}</strong> (household timezone).
        </p>

        <div style="display:flex; gap:0.5rem; justify-content:flex-start;">
            <button type="submit">{{ mode == 'edit' ? 'Save changes' : 'Create event' }}</button>
            {% if mode == 'edit' %}
                <a href="/calendar/events/{{ event.id }}" style="align-self:center; color:var(--muted);">Cancel</a>
            {% else %}
                <a href="/calendar" style="align-self:center; color:var(--muted);">Cancel</a>
            {% endif %}
        </div>
    </form>

    {% if mode == 'edit' %}
        <hr style="border-color:var(--border); margin:1.5rem 0 0.5rem;">
        <form method="POST" action="/calendar/events/{{ event.id }}/delete" style="margin:0;"
              onsubmit="return confirm('Delete this event?');">
            {{ csrf_field() }}
            <button type="submit" class="link" style="background:transparent; border:0; color:var(--error); cursor:pointer; padding:0; font:inherit;">Delete event</button>
        </form>
    {% endif %}
{% endblock %}
