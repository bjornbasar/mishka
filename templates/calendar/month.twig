{% extends "layout.twig" %}

{% block title %}{{ month_label }} — Calendar — {{ brand.name }}{% endblock %}

{% block content %}
    <div class="calendar-header">
        <h1>{{ month_label }}</h1>
        <div class="calendar-nav">
            <a href="/calendar?ym={{ prev_ym }}">← {{ prev_ym }}</a>
            <a href="/calendar" class="today-link">Today</a>
            <a href="/calendar?ym={{ next_ym }}">{{ next_ym }} →</a>
            <a href="/calendar/events/new" class="new-event-link">+ New event</a>
            <a href="/calendar/agenda?ym={{ year }}-{{ '%02d'|format(month) }}" class="agenda-link">Agenda</a>
        </div>
    </div>

    <table class="calendar">
        <thead>
            <tr>
                <th scope="col">Mon</th>
                <th scope="col">Tue</th>
                <th scope="col">Wed</th>
                <th scope="col">Thu</th>
                <th scope="col">Fri</th>
                <th scope="col">Sat</th>
                <th scope="col">Sun</th>
            </tr>
        </thead>
        <tbody>
            {% for row in grid %}
                <tr>
                    {% for cell in row %}
                        <td class="{% if not cell.in_month %}other-month {% endif %}{% if cell.is_today %}today {% endif %}{% if cell.is_weekend %}weekend{% endif %}">
                            {# Day number is pre-formatted in MonthGridBuilder
                               using the household timezone — using Twig's |date
                               filter on cell.date would re-render it in PHP's
                               default tz (UTC in prod), shifting the displayed
                               day by 12-13 hours in NZ. #}
                            <div class="day-number">{{ cell.day_number }}</div>
                            {% for pill in cell.pills %}
                                {% if pill.role == 'overflow' %}
                                    <a href="/calendar/agenda?ym={{ year }}-{{ '%02d'|format(month) }}&day={{ '%02d'|format(cell.day_number) }}" class="event-pill overflow-pill">{{ pill.title }}</a>
                                {% else %}
                                    <a href="/calendar/events/{{ pill.event_id }}" class="event-pill multi-day-{{ pill.role }}">{{ pill.title }}</a>
                                {% endif %}
                            {% endfor %}
                        </td>
                    {% endfor %}
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
