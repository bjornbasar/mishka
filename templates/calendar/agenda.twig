{% extends "layout.twig" %}

{% block title %}Agenda for {{ month_label }} — {{ brand.name }}{% endblock %}

{% block content %}
    <div class="calendar-header">
        <h1>{{ month_label }} — Agenda</h1>
        <div class="calendar-nav">
            <a href="/calendar?ym={{ year }}-{{ '%02d'|format(month) }}">← Month view</a>
            <a href="/calendar/events/new" class="new-event-link">+ New event</a>
        </div>
    </div>

    {% if occurrences|length == 0 %}
        <p style="color:var(--muted);">No events in {{ month_label }}.</p>
    {% else %}
        <ul class="agenda-list">
            {% for o in occurrences %}
                <li class="agenda-item">
                    <div class="agenda-date">
                        {{ o.occurrence.format('D j M, H:i') }}
                        {% if o.is_override %}<span style="color:var(--muted); font-size:0.8em;">(moved)</span>{% endif %}
                    </div>
                    <div class="agenda-content">
                        <a href="/calendar/events/{{ o.event.id }}" class="agenda-title">{{ o.event.title }}</a>
                        {% if o.event.location %}<div class="agenda-location">{{ o.event.location }}</div>{% endif %}
                        {% if o.event.description %}<div class="agenda-description">{{ o.event.description }}</div>{% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
