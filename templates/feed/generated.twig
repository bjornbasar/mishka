{% extends "layout.twig" %}

{% block head_extra %}
    <meta name="referrer" content="no-referrer">
{% endblock %}

{% block title %}Your new feed URL — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>Your new feed URL</h1>
    <p style="color:var(--error); font-weight:bold;">
        Copy this URL now — we won't show it again.
    </p>
    <p>
        Anyone with this URL can read your full calendar, so treat it like a password. If you lose it or
        suspect it's leaked, come back to <a href="/me/calendar/feed">Calendar feed</a> and revoke it.
    </p>

    <section style="background:var(--card); border:1px solid var(--border); padding:1rem 1.25rem; border-radius:0.5rem; margin:1.5rem 0;">
        <h2 style="margin-top:0;">Subscribe in your calendar app</h2>
        <p>
            Most calendar apps accept either of these. The <code>webcal://</code> link will auto-launch your
            default calendar on a phone.
        </p>
        <p>
            <a href="{{ webcal_url }}" rel="noreferrer">{{ webcal_url }}</a>
        </p>
        <p style="font-family:ui-monospace, monospace; font-size:0.9em; background:var(--bg); padding:0.5rem 1rem; border:1px solid var(--border); border-radius:0.375rem; word-break:break-all;">
            {{ feed_url }}
        </p>
    </section>

    <h2>How to add it</h2>
    <ul>
        <li><strong>iOS / macOS Calendar:</strong> tap the <code>webcal://</code> link, then confirm.</li>
        <li><strong>Google Calendar:</strong> Settings → Add calendar → From URL → paste the <code>https://</code> link.</li>
        <li><strong>Outlook:</strong> Add calendar → Subscribe from web → paste the <code>https://</code> link.</li>
    </ul>

    <p>
        <a href="/me/calendar/feed">Back to Calendar feed settings</a>
    </p>
{% endblock %}
