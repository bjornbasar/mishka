<!doctype html>
<html lang="en-NZ">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ brand.name }} — {{ brand.tagline }}{% endblock %}</title>
    <meta name="description" content="{{ brand.tagline }}">
    {# v0.6.0: expose the session-bound CSRF token to JavaScript via a meta
       tag so push-subscribe.js (and any future XHR/fetch caller) can read it
       and send X-CSRF-Token. karhu's Csrf middleware accepts the header form
       OR the form-field form; the meta tag is the simplest reader path. #}
    <meta name="csrf-token" content="{{ csrf_token() }}">
    {% block head_extra %}{% endblock %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Electrolize&family=Rationale&display=swap">
    <style>
        :root {
            color-scheme: light dark;
            --bg: #0f1115;
            --fg: #e6e8ec;
            --muted: #9aa3b2;
            --accent: #b88746;
            --error: #d9534f;
            --card: #161a21;
            --border: #262d38;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            background: var(--bg);
            color: var(--fg);
            line-height: 1.5;
        }
        a { color: var(--accent); text-decoration: none; }
        a:hover { text-decoration: underline; }
        header.top {
            border-bottom: 1px solid var(--border);
            padding: 1rem 1.5rem;
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }
        header.top .brand {
            font-family: 'Electrolize', ui-sans-serif, system-ui, sans-serif;
            font-weight: 700;
            font-size: 1.25rem;
            color: var(--fg);
            letter-spacing: 0.05em;
        }
        h1, h2, h3, h4 {
            font-family: 'Rationale', ui-sans-serif, system-ui, sans-serif;
            letter-spacing: 0.01em;
        }
        header.top nav { display: flex; gap: 1rem; align-items: center; }
        header.top nav form { display: inline; }
        header.top nav button.link,
        header.top nav a {
            background: transparent;
            border: 0;
            color: var(--accent);
            font: inherit;
            cursor: pointer;
            padding: 0;
        }
        main { max-width: 720px; margin: 2rem auto; padding: 0 1.5rem; }
        h1, h2 { margin-top: 0; }
        form.auth { display: flex; flex-direction: column; gap: 1rem; max-width: 28rem; }
        form.auth label { display: flex; flex-direction: column; gap: 0.25rem; }
        form.auth input,
        form.auth select,
        form.auth textarea {
            background: var(--card);
            border: 1px solid var(--border);
            color: var(--fg);
            padding: 0.5rem 0.75rem;
            border-radius: 0.375rem;
            font: inherit;
        }
        /* Drop the browser-default <select> chrome (the light-grey bevel +
           native dropdown arrow) and supply our own arrow via background-SVG
           so it sits flush with the rest of the dark theme. */
        form.auth select {
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
            padding-right: 2rem;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path fill='%239aa3b2' d='M6 8 0 0h12z'/></svg>");
            background-repeat: no-repeat;
            background-position: right 0.75rem center;
        }
        form.auth textarea { font-family: inherit; resize: vertical; min-height: 4.5rem; }
        form.auth button[type=submit] {
            background: var(--accent);
            color: #1a1109;
            border: 0;
            padding: 0.6rem 1rem;
            border-radius: 0.375rem;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
        }
        ul.errors {
            list-style: none;
            padding: 0.75rem 1rem;
            margin: 0 0 1rem;
            background: rgba(217, 83, 79, 0.1);
            border: 1px solid var(--error);
            border-radius: 0.375rem;
            color: var(--error);
        }
        ul.errors li { padding: 0.125rem 0; }
        .flash {
            background: var(--card);
            border: 1px solid var(--accent);
            padding: 0.75rem 1rem;
            border-radius: 0.375rem;
            margin-bottom: 1rem;
        }
        footer { color: var(--muted); padding: 2rem 1.5rem; text-align: center; font-size: 0.875rem; }

        /* v0.3 calendar */
        .calendar-header { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem; }
        .calendar-nav { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
        .calendar-nav a { color: var(--accent); }
        .calendar-nav .new-event-link, .calendar-nav .agenda-link { color: var(--fg); border: 1px solid var(--border); padding: 0.25rem 0.75rem; border-radius: 0.375rem; }
        .calendar { width: 100%; border-collapse: collapse; background: var(--card); border: 1px solid var(--border); table-layout: fixed; }
        .calendar th { background: var(--card); color: var(--accent); font-weight: 700; padding: 0.6rem; text-align: center; border-bottom: 2px solid var(--border); font-size: 0.875rem; }
        .calendar td { border: 1px solid var(--border); padding: 0.4rem; vertical-align: top; height: 6rem; overflow: hidden; }
        .calendar td .day-number { font-size: 0.85em; color: var(--muted); margin-bottom: 0.25rem; }
        .calendar td.other-month { background: rgba(255, 255, 255, 0.02); }
        .calendar td.other-month .day-number { color: rgba(154, 163, 178, 0.4); }
        .calendar td.today { border-color: var(--accent); }
        .calendar td.today .day-number { color: var(--accent); font-weight: 700; }
        .calendar td.weekend { background: rgba(255, 255, 255, 0.01); }
        .event-pill { display: block; background: var(--accent); color: #1a1109; padding: 0.15rem 0.4rem; border-radius: 0.25rem; font-size: 0.75rem; margin-top: 0.2rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-decoration: none; }
        .event-pill:hover { text-decoration: none; filter: brightness(1.1); }
        .multi-day-start { border-top-right-radius: 0; border-bottom-right-radius: 0; }
        .multi-day-mid { border-radius: 0; }
        .multi-day-end { border-top-left-radius: 0; border-bottom-left-radius: 0; }
        .overflow-pill { background: var(--card); border: 1px solid var(--border); color: var(--muted); }

        .agenda-list { list-style: none; padding: 0; margin: 0; }
        .agenda-item { display: flex; gap: 1rem; border-left: 3px solid var(--accent); padding: 0.6rem 0.9rem; margin-bottom: 0.6rem; background: var(--card); border-radius: 0.25rem; }
        .agenda-date { color: var(--accent); font-weight: 600; min-width: 11rem; font-size: 0.9em; }
        .agenda-content { flex: 1; }
        .agenda-title { color: var(--fg); font-weight: 600; text-decoration: none; }
        .agenda-location { color: var(--muted); font-size: 0.85em; margin-top: 0.15rem; }
        .agenda-description { color: var(--muted); font-size: 0.9em; margin-top: 0.25rem; }

        @media (max-width: 700px) {
            .calendar { display: none; }
            /* On narrow viewports the month view stays but the user clicks "Agenda" — no JS swap. */
        }

        /* v0.5.1 chore cards — day-grouped to-do list. The .chore-card
           wraps the Done button + the chore body; the left-border accent
           communicates urgency (red for overdue, accent for today, muted
           for upcoming) without shouting. */
        .chore-day-heading {
            font-size: 0.95rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--muted);
            margin: 1.25rem 0 0.5rem;
            padding-bottom: 0.25rem;
            border-bottom: 1px solid var(--border);
        }
        .chore-day-heading.is-overdue { color: var(--error); border-bottom-color: var(--error); }
        .chore-day-heading.is-today   { color: var(--accent); border-bottom-color: var(--accent); }
        .chore-card-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
        .chore-card {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.65rem 0.85rem;
            background: var(--card);
            border: 1px solid var(--border);
            border-left: 4px solid var(--border);
            border-radius: 0.4rem;
            transition: border-color 0.15s ease, transform 0.1s ease;
        }
        .chore-card:hover { border-color: var(--accent); }
        .chore-card.is-today { border-left-color: var(--accent); }
        .chore-card.is-overdue { border-left-color: var(--error); }
        .chore-done-form { margin: 0; }
        .btn-done {
            background: var(--accent);
            color: #1a1109;
            border: 0;
            padding: 0.45rem 0.85rem;
            border-radius: 0.35rem;
            font-weight: 600;
            font-size: 0.875rem;
            cursor: pointer;
            white-space: nowrap;
        }
        .btn-done:hover { filter: brightness(1.1); }
        .btn-done:active { transform: translateY(1px); }
        .chore-card-body { flex: 1; display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
        .chore-card-title {
            color: var(--fg);
            font-weight: 600;
            text-decoration: none;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .chore-card-title:hover { text-decoration: underline; }
        .chore-card-meta { color: var(--muted); font-size: 0.85em; }

        /* Recurrence form: show only the fields relevant to the selected
           preset. Toggled via a `data-preset` attribute that a one-line
           inline `onchange` on the <select> keeps in sync. Older versions
           used `:has(select [value="X"]:checked)` + inline `style="display:none;"`
           on the labels — that combination silently never worked because
           inline styles beat class selectors without `!important`, so the
           weekly checkboxes, monthly day input, and interval input were
           always hidden regardless of the preset. */
        /* Hide rule is prefixed with `.recurrence-fieldset` to push its
           specificity to (0,2,0) — otherwise `form.auth label` at (0,1,2)
           wins the cascade and the sub-fields render `display: flex` even
           when the preset doesn't call for them. The show rules below sit at
           (0,3,0) and beat both. */
        .recurrence-fieldset .recurrence-weekly,
        .recurrence-fieldset .recurrence-monthly,
        .recurrence-fieldset .recurrence-interval { display: none; }
        .recurrence-fieldset[data-preset="weekly"] .recurrence-weekly,
        .recurrence-fieldset[data-preset="weekly"] .recurrence-interval,
        .recurrence-fieldset[data-preset="monthly"] .recurrence-monthly,
        .recurrence-fieldset[data-preset="monthly"] .recurrence-interval,
        .recurrence-fieldset[data-preset="daily"] .recurrence-interval,
        .recurrence-fieldset[data-preset="yearly"] .recurrence-interval { display: flex; }

        /* v0.6.0 mobile polish — 5 @media rules covering the 80% of pain
           identified in the v0.6 plan's mobile survey at 375px (iPhone SE
           width). No markup changes; pure additive CSS. */
        @media (max-width: 700px) {
            /* 1. Agenda items stack date above content (date had min-width:
                  11rem which ate 53% of a 375px viewport). */
            .agenda-item { flex-direction: column; gap: 0.5rem; }
            .agenda-date { min-width: auto; }

            /* 2. Chore cards stack the Done button above the body so it's
                  full-width tappable instead of a narrow inline button. */
            .chore-card { flex-direction: column; align-items: stretch; }
            .btn-done { width: 100%; }

            /* 3. Household-switcher dropdown — was position: absolute right: 0
                  which overflowed the right edge on narrow viewports. Pin to
                  the viewport edges instead. */
            header.top nav details[open] > div,
            header.top nav .household-switcher > div {
                position: fixed;
                left: 1rem;
                right: 1rem;
                width: auto;
                min-width: 0;
            }

            /* 4. Calendar nav (← Month → Today Agenda) centred + on its own
                  line below the heading. */
            .calendar-header { justify-content: center; }
            .calendar-nav { justify-content: center; flex-basis: 100%; }

            /* 5. Touch-tappable buttons (48px Apple recommendation). */
            .btn-done,
            form.auth button[type=submit],
            .new-event-link { min-height: 48px; }
        }
    </style>
</head>
<body>
    <header class="top">
        <a href="/" class="brand">{{ brand.name }}</a>
        <nav>
            {% if session_email is defined and session_email %}
                {% if active_household is defined and active_household %}
                    <a href="/calendar">Calendar</a>
                    <a href="/chores">Chores</a>
                    <a href="/household">Household</a>
                    <a href="/me/calendar/feed">Feed</a>
                {% endif %}
                {% if households is defined and households|length > 1 %}
                    {% include "_partials/household_switcher.twig" %}
                {% endif %}
                <span>{{ session_email }}</span>
                <a href="/me/notifications" title="Notification preferences" style="font-size:0.85em;">🔔</a>
                <form method="POST" action="/logout">
                    {{ csrf_field() }}
                    <button type="submit" class="link">Sign out</button>
                </form>
            {% else %}
                <a href="/login">Sign in</a>
                <a href="/register">Register</a>
            {% endif %}
        </nav>
    </header>

    <main>
        {# v0.5.0: single-copy verify banner (decision U-3). Hides SMTP-fail
           state from non-technical users; sent_at NULL stays in DB for ops. #}
        {% if verify_required is defined and verify_required %}
            <div class="flash" style="border-color: var(--muted); color: var(--muted);">
                Please verify your email —
                <form method="POST" action="/me/verify-email/resend" style="display: inline;">
                    {{ csrf_field() }}
                    <button type="submit" class="link" style="color: var(--accent); text-decoration: underline;">Resend</button>
                </form>
            </div>
        {% endif %}
        {% if flash is defined and flash %}
            <div class="flash">{{ flash }}</div>
        {% endif %}
        {% block content %}{% endblock %}
    </main>

    <footer>
        {{ brand.name }} — {{ brand.tagline }}
        · <a href="/help" style="color: var(--accent);">Help</a>
    </footer>

    {# v0.6.0: register the service worker (covers / scope). The SW only
       listens for `push` events; no fetch interception, no caching. Loads on
       every page including pre-login — harmless because the SW can't receive
       a push without a corresponding server-side dispatch authenticated by
       VAPID. Browsers that don't support service workers silently skip. #}
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js').catch(function (err) {
                console.warn('service worker registration failed:', err);
            });
        }
    </script>
</body>
</html>
