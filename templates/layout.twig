<!doctype html>
<html lang="en-NZ">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ brand.name }} — {{ brand.tagline }}{% endblock %}</title>
    <meta name="description" content="{{ brand.tagline }}">
    <style>
        :root {
            color-scheme: light dark;
            --bg: #0f1115;
            --fg: #e6e8ec;
            --muted: #9aa3b2;
            --accent: #b88746;
            --error: #d9534f;
            --card: #161a21;
            --border: #262d38;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            background: var(--bg);
            color: var(--fg);
            line-height: 1.5;
        }
        a { color: var(--accent); text-decoration: none; }
        a:hover { text-decoration: underline; }
        header.top {
            border-bottom: 1px solid var(--border);
            padding: 1rem 1.5rem;
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }
        header.top .brand {
            font-weight: 700;
            font-size: 1.25rem;
            color: var(--fg);
        }
        header.top nav { display: flex; gap: 1rem; align-items: center; }
        header.top nav form { display: inline; }
        header.top nav button.link,
        header.top nav a {
            background: transparent;
            border: 0;
            color: var(--accent);
            font: inherit;
            cursor: pointer;
            padding: 0;
        }
        main { max-width: 720px; margin: 2rem auto; padding: 0 1.5rem; }
        h1, h2 { margin-top: 0; }
        form.auth { display: flex; flex-direction: column; gap: 1rem; max-width: 28rem; }
        form.auth label { display: flex; flex-direction: column; gap: 0.25rem; }
        form.auth input {
            background: var(--card);
            border: 1px solid var(--border);
            color: var(--fg);
            padding: 0.5rem 0.75rem;
            border-radius: 0.375rem;
            font: inherit;
        }
        form.auth button[type=submit] {
            background: var(--accent);
            color: #1a1109;
            border: 0;
            padding: 0.6rem 1rem;
            border-radius: 0.375rem;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
        }
        ul.errors {
            list-style: none;
            padding: 0.75rem 1rem;
            margin: 0 0 1rem;
            background: rgba(217, 83, 79, 0.1);
            border: 1px solid var(--error);
            border-radius: 0.375rem;
            color: var(--error);
        }
        ul.errors li { padding: 0.125rem 0; }
        .flash {
            background: var(--card);
            border: 1px solid var(--accent);
            padding: 0.75rem 1rem;
            border-radius: 0.375rem;
            margin-bottom: 1rem;
        }
        footer { color: var(--muted); padding: 2rem 1.5rem; text-align: center; font-size: 0.875rem; }
    </style>
</head>
<body>
    <header class="top">
        <a href="/" class="brand">{{ brand.name }}</a>
        <nav>
            {% if session_email is defined and session_email %}
                {% if households is defined and households|length > 1 %}
                    {% include "_partials/household_switcher.twig" %}
                {% endif %}
                <span>{{ session_email }}</span>
                <form method="POST" action="/logout">
                    {{ csrf_field() }}
                    <button type="submit" class="link">Sign out</button>
                </form>
            {% else %}
                <a href="/login">Sign in</a>
                <a href="/register">Register</a>
            {% endif %}
        </nav>
    </header>

    <main>
        {% if flash is defined and flash %}
            <div class="flash">{{ flash }}</div>
        {% endif %}
        {% block content %}{% endblock %}
    </main>

    <footer>{{ brand.name }} — {{ brand.tagline }}</footer>
</body>
</html>
