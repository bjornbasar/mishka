{% extends "layout.twig" %}

{% block title %}Notifications — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>Notifications</h1>

    {% if errors %}
        <ul class="errors">
            {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    {# v0.6.0: subscribe-this-device button + active-device list. The
       VAPID public key is exposed as a `data-` attribute on the wrapper so
       push-subscribe.js can read it without an extra fetch. #}
    <section class="notifications-block"
             data-vapid-public-key="{{ vapid_public_key }}"
             style="background:var(--card); border:1px solid var(--border); padding:1rem; border-radius:0.5rem; margin-bottom:1.5rem;">
        <h2 style="margin:0 0 0.75rem; font-size:1.1rem;">Devices</h2>
        <button type="button" id="enable-push" class="btn-done">Enable on this device</button>
        <p style="color:var(--muted); font-size:0.9em; margin:0.75rem 0 0;">
            iPhone? You'll need to install Mishka as a home-screen app first (iOS 16.4+). See
            <a href="/help#notifications">Notifications</a> in the user guide for the steps.
        </p>

        {% if subscriptions|length > 0 %}
            <h3 style="margin:1.25rem 0 0.5rem; font-size:0.95rem;">Subscribed devices</h3>
            <ul style="list-style:none; padding:0; margin:0;">
                {% for sub in subscriptions %}
                    <li style="display:flex; align-items:center; gap:0.5rem; padding:0.5rem 0; border-top:1px solid var(--border);">
                        <span style="flex:1;">
                            {{ sub.user_agent|default('Unknown device') }}
                            <small style="color:var(--muted); display:block;">
                                added {{ sub.created_at|slice(0, 10) }} ·
                                {% if sub.last_used_at %}last used {{ sub.last_used_at|slice(0, 10) }}{% else %}never used{% endif %}
                            </small>
                        </span>
                        <form method="POST" action="/me/push/subscriptions/{{ sub.id }}/delete" style="margin:0;"
                              onsubmit="return confirm('Stop sending push notifications to this device?');">
                            {{ csrf_field() }}
                            <button type="submit" class="link" style="background:transparent; border:1px solid var(--border); color:var(--muted); padding:0.25rem 0.6rem; border-radius:0.25rem; cursor:pointer;">Revoke</button>
                        </form>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>

    <form method="POST" action="/me/notifications" class="auth" style="max-width:30rem;">
        {{ csrf_field() }}
        <label>
            Event reminder
            <select name="event_reminder_minutes">
                {% set reminder_options = {'0':'Off', '5':'5 minutes before', '10':'10 minutes before', '15':'15 minutes before', '30':'30 minutes before', '60':'1 hour before', '120':'2 hours before'} %}
                {% for value, label in reminder_options %}
                    <option value="{{ value }}" {% if prefs.event_reminder_minutes == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
        </label>
        <label style="flex-direction:row; align-items:center; gap:0.5rem;">
            <input type="checkbox" name="overdue_chore_digest" {% if prefs.overdue_chore_digest %}checked{% endif %}>
            Daily 7:30–8:30am digest if I have overdue chores
        </label>
        <button type="submit">Save preferences</button>
    </form>

    <form method="POST" action="/me/push/test" style="margin-top:1.5rem;">
        {{ csrf_field() }}
        <button type="submit" class="btn-done">Send test push</button>
    </form>

    <p style="margin-top:1.5rem;">
        <a href="/me/profile">← Back to profile</a>
    </p>

    {# Service worker registration + subscribe glue. Inline so we don't need a
       build pipeline. The script reads `data-vapid-public-key` from the wrapper. #}
    <script src="/push-subscribe.js"></script>
{% endblock %}
