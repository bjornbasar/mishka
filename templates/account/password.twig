{% extends "layout.twig" %}

{% block title %}Change password — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>Change password</h1>

    {% if errors %}
        <ul class="errors">
            {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    <form method="POST" action="/me/password" class="auth">
        {{ csrf_field() }}
        <label>
            Current password
            <input type="password" name="current_password" required autofocus>
        </label>
        <label>
            New password
            <input type="password" name="new_password" required minlength="12" maxlength="128">
        </label>
        <label>
            Confirm new password
            <input type="password" name="new_password_confirm" required minlength="12" maxlength="128">
        </label>
        <button type="submit">Update password</button>
    </form>

    <p style="margin-top: 24px;">
        <a href="/me/profile">← Back to profile</a>
    </p>
{% endblock %}
