{% extends "layout.twig" %}

{% block title %}Promote user to admin — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>Promote another user to system admin</h1>

    {% if is_only_admin %}
        <p style="color: var(--muted, #666);">
            You are currently the only system administrator. Promote a deputy
            so you can delete your account, or just add admin redundancy.
        </p>
    {% else %}
        <p style="color: var(--muted, #666);">
            Promote-only — your own admin role is unchanged. Select a user
            below; they gain the admin role immediately. To remove your own
            admin status, delete your account (the FK cascade revokes it).
        </p>
    {% endif %}

    {% if errors %}
        <ul class="errors">
            {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    {% if candidates|length == 0 %}
        <p style="margin-top: 16px;">
            There are no other users to promote. Wait for another user to register
            before you can promote them.
        </p>
    {% else %}
        <form method="POST" action="/me/admin/promote" class="auth" style="margin-top: 16px;">
            {{ csrf_field() }}
            <label>
                User
                <select name="target_user_id" required>
                    {% for u in candidates %}
                        <option value="{{ u.id }}">{{ u.display_name }} &lt;{{ u.email }}&gt;</option>
                    {% endfor %}
                </select>
            </label>
            <button type="submit">Promote to system admin</button>
        </form>
    {% endif %}

    <p style="margin-top: 24px;">
        <a href="/me/profile">← Back to profile</a>
    </p>
{% endblock %}
