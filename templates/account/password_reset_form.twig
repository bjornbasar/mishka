{% extends "layout.twig" %}

{% block title %}Set a new password — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>Set a new password</h1>

    {% if errors %}
        <ul class="errors">
            {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    <form method="POST" action="/password-reset/{{ token }}" class="auth">
        {{ csrf_field() }}
        <label>
            New password
            <input type="password" name="new_password" required minlength="12" maxlength="128" autofocus>
        </label>
        <label>
            Confirm new password
            <input type="password" name="new_password_confirm" required minlength="12" maxlength="128">
        </label>
        <button type="submit">Set new password</button>
    </form>
{% endblock %}
