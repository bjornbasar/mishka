{% extends "layout.twig" %}

{% block title %}Your profile — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>Your profile</h1>

    {% if errors %}
        <ul class="errors">
            {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    <form method="POST" action="/me/profile" class="auth">
        {{ csrf_field() }}
        <label>
            Display name
            <input type="text" name="display_name" required autofocus
                   maxlength="120" value="{{ display_name|default('') }}">
        </label>
        <button type="submit">Save</button>
    </form>

    <p style="margin-top: 24px;">
        <a href="/me/password">Change password →</a>
    </p>
    <p>
        <a href="/me/email">Change email →</a>
    </p>
    <p>
        <a href="/badges">🏆 Your badges</a>
    </p>
    <p>
        <a href="/me/sessions">🔒 Active sessions</a>
    </p>
    {% if is_system_admin %}
        <p>
            <a href="/me/admin/promote">Promote another user to system admin →</a>
        </p>
    {% endif %}
    <p style="margin-top: 32px;">
        <a href="/me/delete" style="color: #c00;">Delete account →</a>
    </p>
    <p>
        <a href="/">← Back to home</a>
    </p>
{% endblock %}
