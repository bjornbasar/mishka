{% extends "layout.twig" %}

{% block title %}Link invalid — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>This reset link is invalid or expired</h1>

    <p>
        Password reset links work once and expire after 1 hour. If you still need
        to reset your password, request a new link.
    </p>

    <p>
        <a href="/password-reset">Request a new reset link →</a>
    </p>

    <p style="margin-top: 24px;">
        <a href="/login">← Back to sign in</a>
    </p>
{% endblock %}
