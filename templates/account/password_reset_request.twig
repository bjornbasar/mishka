{% extends "layout.twig" %}

{% block title %}Reset your password — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>Reset your password</h1>

    <p>Enter your email below and we'll send you a link to set a new password.</p>

    <form method="POST" action="/password-reset" class="auth">
        {{ csrf_field() }}
        <label>
            Email
            <input type="email" name="email" required autofocus
                   maxlength="320" value="{{ old.email|default('') }}">
        </label>
        <button type="submit">Send reset link</button>
    </form>

    <p style="margin-top: 24px;">
        <a href="/login">← Back to sign in</a>
    </p>
{% endblock %}
