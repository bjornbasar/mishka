{% extends "layout.twig" %}

{% block title %}Change email — {{ brand.name }}{% endblock %}

{% block content %}
    <h1>Change email</h1>

    <p>Current email: <strong>{{ current_email }}</strong></p>

    {% if errors %}
        <ul class="errors">
            {% for error in errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    <form method="POST" action="/me/email" class="auth">
        {{ csrf_field() }}
        <label>
            New email
            <input type="email" name="new_email" required maxlength="320"
                   value="{{ new_email|default('') }}" autofocus>
        </label>
        <label>
            Current password (to confirm it's really you)
            <input type="password" name="current_password" required>
        </label>
        <button type="submit">Send confirmation link</button>
    </form>

    <p style="margin-top: 16px; color: var(--muted, #666); font-size: 14px;">
        We'll send a confirmation link to your new address. The change won't
        apply until you click that link. Your current email stays active until
        then.
    </p>

    <p style="margin-top: 24px;">
        <a href="/me/profile">← Back to profile</a>
    </p>
{% endblock %}
