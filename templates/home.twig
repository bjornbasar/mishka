{% extends "layout.twig" %}

{% block content %}
    {% if active_household %}
        <h1>Welcome back</h1>
        <p>You're in <strong>{{ active_household.name }}</strong>. <a href="/household">Manage household</a></p>
        <p style="color:var(--muted);">Calendar, chores, lists, and meal plans are still on the way. For now this is your hub — the rest of mishka is being built around it.</p>
    {% elseif session_email %}
        {# Logged in but no active household — HomeController normally redirects
           to /household/setup before this template renders, but in case of a
           transient state, give the user a path forward. #}
        <h1>Welcome back, {{ session_email }}</h1>
        <p>You don't have a household yet. <a href="/household/setup">Create or join one</a> to get started.</p>
    {% else %}
        <h1>{{ brand.name }}</h1>
        <p>{{ brand.tagline|capitalize }}. mishka is a quiet command-centre for the household — calendar, chores, lists, and the everyday coordination a family needs, in one place.</p>
        <p><a href="/register">Create an account</a> · <a href="/login">Sign in</a></p>
    {% endif %}
{% endblock %}
