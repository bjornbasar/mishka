{% extends "layout.twig" %}

{% block title %}Health — {{ brand.name }}{% endblock %}

{% block content %}
    <div class="calendar-header">
        <h1>Health</h1>
        <div class="calendar-nav">
            <a href="/health/foods" class="new-event-link">Foods</a>
            <a href="/health/exercises" class="new-event-link">Exercises</a>
            <a href="/health/weight" class="new-event-link">Weight</a>
            <a href="/health/profile" class="new-event-link">Profile</a>
            <a href="/health/leaderboard" class="new-event-link">Leaderboard</a>
        </div>
    </div>

    <p style="color:var(--muted); margin:0 0 1rem;">
        {{ today }} · {{ day_total }} kcal so far today
    </p>

    {# v0.8.2 — energy-balance widget (per-user, private). Three states:
       needs_profile → CTA to set up profile
       needs_weight  → CTA to record weight (profile complete)
       complete      → intake vs expenditure breakdown with net
       See DOCS #72. #}
    <section style="background:var(--card); border:1px solid var(--border); padding:0.75rem 1rem; border-radius:0.5rem; margin-bottom:1.5rem;">
        {% if balance.state == 'needs_profile' %}
            <h2 style="font-size:1.1rem; margin:0 0 0.5rem;">Set up your profile to see your daily balance</h2>
            <p style="margin:0 0 0.5rem; color:var(--muted); font-size:0.95rem;">
                Enter sex, birth year, height, and base-activity level. Combined with your weight, this gives Mishka the numbers to compute your daily energy balance.
            </p>
            <p style="margin:0;"><a href="/health/profile">Set up profile →</a></p>
        {% elseif balance.state == 'needs_weight' %}
            <h2 style="font-size:1.1rem; margin:0 0 0.5rem;">Record your weight to see your daily balance</h2>
            <p style="margin:0 0 0.5rem; color:var(--muted); font-size:0.95rem;">
                Your profile is set. Log your current weight so BMR (Mifflin-St Jeor) can compute.
            </p>
            <p style="margin:0;"><a href="/health/weight">Record weight →</a></p>
        {% else %}
            {# state == 'complete' — show intake / expenditure / net breakdown. #}
            <h2 style="font-size:1.1rem; margin:0 0 0.5rem;">Today's balance</h2>
            <div style="display:flex; justify-content:space-between; gap:1rem; margin-bottom:0.5rem;">
                <span>Intake: <strong>{{ balance.intake }} kcal</strong></span>
                <span>Expenditure: <strong>{{ balance.expenditure }} kcal</strong></span>
            </div>
            <p style="margin:0.25rem 0 0.75rem; font-size:1.1rem;">
                Net: <strong>{{ balance.net > 0 ? '+' : '' }}{{ balance.net }} kcal</strong>
            </p>
            <ul style="list-style:none; padding:0; margin:0; font-size:0.9rem; color:var(--muted);">
                <li>BMR: {{ balance.bmr }} kcal <small>(Mifflin-St Jeor)</small></li>
                <li title="Your normal day EXCLUDING logged workouts. Double-counting your gym time here would inflate expenditure.">Activity: {{ balance.activity_delta }} kcal <small>(base_activity {{ balance.base_activity }} — excluding workouts)</small></li>
                <li>Exercise: {{ balance.exercise }} kcal <small>(from your logged workouts)</small></li>
            </ul>
        {% endif %}
    </section>

    {% set meal_labels = {'breakfast': '🍳 Breakfast', 'lunch': '🥗 Lunch', 'dinner': '🍽️ Dinner', 'snack': '🍎 Snack'} %}
    {% set total_entries = 0 %}
    {% for meal, entries in meal_groups %}{% set total_entries = total_entries + entries|length %}{% endfor %}

    {% if total_entries == 0 %}
        <p style="color:var(--muted);">Nothing logged yet today. Tap <strong>+ Add</strong> on any meal below to start.</p>
    {% endif %}

    {% for meal, entries in meal_groups %}
        <section style="margin-bottom:1.5rem;">
            <h2 style="font-size:1.1rem; margin-bottom:0.5rem;">
                {{ meal_labels[meal] }}
                <a href="/health/log/food?meal={{ meal }}" style="float:right; font-size:0.9rem;">+ Add</a>
            </h2>
            {% if entries|length == 0 %}
                <p style="color:var(--muted); margin:0; font-size:0.9rem;">—</p>
            {% else %}
                <ul style="list-style:none; padding:0; margin:0;">
                    {% for e in entries %}
                        <li style="border-bottom:1px solid var(--border); padding:0.5rem 0; display:flex; justify-content:space-between; align-items:center;">
                            <span>
                                {{ e.qty }} × {{ e.food_name }}
                                <small style="color:var(--muted);">({{ e.serving_label }})</small>
                            </span>
                            <span>
                                <strong>{{ e.kcal_snapshot }} kcal</strong>
                                <form method="POST" action="/health/log/food/{{ e.id }}/delete" style="display:inline; margin-left:0.5rem;">
                                    {{ csrf_field() }}
                                    <button type="submit" style="background:transparent; border:none; color:var(--muted); cursor:pointer;" title="Remove">✕</button>
                                </form>
                            </span>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </section>
    {% endfor %}

    {# v0.8.1 — Exercise section below meals. #}
    <section style="margin-bottom:1.5rem;">
        <h2 style="font-size:1.1rem; margin-bottom:0.5rem;">
            🏃 Exercise
            <a href="/health/log/exercise" style="float:right; font-size:0.9rem;">+ Add</a>
        </h2>
        {% if exercise_entries|length == 0 %}
            <p style="color:var(--muted); margin:0; font-size:0.9rem;">Nothing logged. Tap <strong>+ Add</strong> to log today's workout.</p>
        {% else %}
            <ul style="list-style:none; padding:0; margin:0;">
                {% for e in exercise_entries %}
                    <li style="border-bottom:1px solid var(--border); padding:0.5rem 0; display:flex; justify-content:space-between; align-items:center;">
                        <span>
                            <strong>{{ e.exercise_name }}</strong>
                            {% if e.exercise_type == 'duration' %}
                                <small style="color:var(--muted);">— {{ e.minutes }} min</small>
                            {% else %}
                                <small style="color:var(--muted);">— {{ e.sets }} × {{ e.reps }}{% if e.load_kg %} @ {{ e.load_kg }} kg{% endif %}</small>
                            {% endif %}
                        </span>
                        <span>
                            {% if e.met_minutes %}<small style="color:var(--muted);">{{ e.met_minutes }} MET-min · </small>{% endif %}
                            <strong>{{ e.kcal_snapshot ?: '—' }} kcal</strong>
                            <form method="POST" action="/health/log/exercise/{{ e.id }}/delete" style="display:inline; margin-left:0.5rem;">
                                {{ csrf_field() }}
                                <button type="submit" style="background:transparent; border:none; color:var(--muted); cursor:pointer;" title="Remove">✕</button>
                            </form>
                        </span>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>
{% endblock %}
