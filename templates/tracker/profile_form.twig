{% extends "layout.twig" %}

{% block title %}{% if profile %}Edit profile{% else %}Set up profile{% endif %} — {{ brand.name }}{% endblock %}

{% block content %}
    <div class="calendar-header">
        <h1>{% if profile %}Edit profile{% else %}Set up your profile{% endif %}</h1>
        <div class="calendar-nav">
            <a href="/health" class="new-event-link">← Today</a>
        </div>
    </div>

    <p style="color:var(--muted); margin:0 0 1rem;">
        Your profile drives the daily energy-balance calculation.
        {% if latest_weight %}
            Current weight: <strong>{{ latest_weight.weight_kg }} kg</strong>
            (recorded {{ latest_weight.measured_on }}).
        {% else %}
            No weight recorded yet — <a href="/health/weight">record one first</a> to see BMR.
        {% endif %}
    </p>

    {% if errors %}
        <ul class="errors">
            {% for e in errors %}<li>{{ e }}</li>{% endfor %}
        </ul>
    {% endif %}

    {% if bmr_preview %}
        <p style="color:var(--muted); margin:0 0 1rem;">
            <strong>BMR preview:</strong> {{ bmr_preview }} kcal/day
            <small>(Mifflin-St Jeor; changes with weight)</small>
        </p>
    {% endif %}

    <form method="POST" action="/health/profile" class="auth">
        {{ csrf_field() }}
        {% set current_sex = old.sex|default(profile.sex|default('')) %}
        {% set current_by = old.birth_year|default(profile.birth_year|default('')) %}
        {% set current_h = old.height_cm|default(profile.height_cm|default('')) %}
        {% set current_ba = old.base_activity|default(profile.base_activity|default('1.375')) %}

        <label>
            Sex
            <select name="sex" required>
                <option value=""{% if current_sex == '' %} selected{% endif %} disabled>—</option>
                <option value="male"{% if current_sex == 'male' %} selected{% endif %}>Male</option>
                <option value="female"{% if current_sex == 'female' %} selected{% endif %}>Female</option>
            </select>
        </label>
        <label>
            Birth year <small style="color:var(--muted);">(e.g. 1985)</small>
            <input type="number" name="birth_year" value="{{ current_by }}" min="1900" max="{{ 'now'|date('Y') - 5 }}" step="1" required>
        </label>
        <label>
            Height (cm)
            <input type="number" name="height_cm" value="{{ current_h }}" min="50" max="250" step="0.1" required>
        </label>
        <label>
            Base activity <small style="color:var(--muted);">— YOUR NORMAL DAY EXCLUDING WORKOUTS</small>
            <select name="base_activity" required>
                <option value="1.200"{% if current_ba == '1.200' or current_ba == '1.2' %} selected{% endif %}>Sedentary — desk job, little walking (1.20)</option>
                <option value="1.375"{% if current_ba == '1.375' %} selected{% endif %}>Lightly active — some walking or light chores (1.375)</option>
                <option value="1.550"{% if current_ba == '1.550' or current_ba == '1.55' %} selected{% endif %}>Moderately active — on your feet most of the day (1.55)</option>
                <option value="1.725"{% if current_ba == '1.725' %} selected{% endif %}>Very active — physical job / lots of walking (1.725)</option>
            </select>
            <p style="color:var(--muted); font-size:0.9rem; margin:0.25rem 0 0;">
                Deliberate workouts are logged separately in the Exercise section.
                Choosing a higher number here would double-count them.
            </p>
        </label>

        <button type="submit" style="margin-top:1rem;">{% if profile %}Save{% else %}Set up profile{% endif %}</button>
    </form>
{% endblock %}
