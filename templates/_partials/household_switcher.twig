{# Household switcher — only renders when the user has 2+ memberships. Each
   row is a tiny POST form so we get CSRF protection without JS. All styling
   moved to layout.twig CSS in v0.6.5; inline styles were fighting the @media
   override on narrow viewports (dropdown's inline `top: 1.5rem` was being
   interpreted against the viewport once @media set `position: fixed`). #}
{% if households|length > 1 %}
    <details class="household-switcher">
        <summary>{{ active_household.name|default('Switch household') }} ▾</summary>
        <div class="household-switcher-list">
            {% for h in households %}
                <form method="POST" action="/household/switch">
                    {{ csrf_field() }}
                    <input type="hidden" name="household_id" value="{{ h.id }}">
                    <button type="submit"{% if h.id == active_household.id|default(0) %} class="is-active"{% endif %}>
                        {{ h.name }}
                        <small>{{ h.role|capitalize }}</small>
                    </button>
                </form>
            {% endfor %}
        </div>
    </details>
{% endif %}
