{
    "name": "bjornbasar/mishka",
    "description": "Mishka Den — the den mother for your family",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "bjornbasar/karhu": "^0.1.2",
        "bjornbasar/karhu-db": "^0.1",
        "bjornbasar/karhu-queue": "dev-main",
        "bjornbasar/karhu-view": "^0.1",
        "league/commonmark": "^2.0",
        "minishlink/web-push": "^9.0",
        "sabre/vobject": "^4.5",
        "simshaun/recurr": "^6.0",
        "symfony/mailer": "^7.2",
        "symfony/mime": "^7.2",
        "twig/twig": "^3.10",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "App\\": "app/" }
    },
    "autoload-dev": {
        "psr-4": { "App\\Tests\\": "tests/" }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": { "sort-packages": true },
    "scripts": {
        "serve": "php -S localhost:8080 -t public",
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "karhu": "karhu"
    }
}
